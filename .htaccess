Options -MultiViews
RewriteEngine On

# Redireciona acessos com .html para a URL limpa (301 permanente)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve o arquivo .html internamente quando a URL não tem extensão
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
